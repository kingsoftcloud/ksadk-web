{
  "name": "@kingsoftcloud/ksadk-web",
  "version": "0.2.14",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:ksadk",
    "build:hosted": "VITE_BASE_PATH=/chat/ vite build --outDir dist-hosted",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build:all": "npm run build:ksadk && npm run build:hosted && npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run src",
    "test:watch": "vitest src",
    "build:ksadk": "VITE_BASE_PATH=./ vite build --outDir dist-ksadk"
  },
  "exports": {
    ".": {
      "types": "./dist-lib/public/runtime.d.ts",
      "import": "./dist-lib/runtime.js"
    },
    "./components": {
      "types": "./dist-lib/public/components.d.ts",
      "import": "./dist-lib/components.js"
    },
    "./runtime": {
      "types": "./dist-lib/public/runtime.d.ts",
      "import": "./dist-lib/runtime.js"
    },
    "./capabilities": {
      "types": "./dist-lib/public/capabilities.d.ts",
      "import": "./dist-lib/capabilities.js"
    },
    "./styles": "./dist-lib/styles.css",
    "./types": {
      "types": "./dist-lib/public/types.d.ts",
      "import": "./dist-lib/types.js"
    }
  },
  "files": [
    "dist-lib",
    "dist-ksadk",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "dist-lib/*.css"
  ],
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "eventsource-parser": "^3.0.6",
    "framer-motion": "^12.38.0",
    "katex": "^0.16.44",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.13.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.4.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.6"
  },
  "description": "Shared Web UI source for AgentEngine hosted UI and KSADK static UI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingsoftcloud/ksadk-web.git"
  },
  "bugs": {
    "url": "https://github.com/kingsoftcloud/ksadk-web/issues"
  },
  "homepage": "https://kingsoftcloud.github.io/ksadk-web/"
}
